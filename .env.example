# ------------------------------------------------------------------------------
# Application
# ------------------------------------------------------------------------------

# Runtime environment: dev, test, or prod.
APP_ENV=dev

# Log verbosity level.
LOG_LEVEL=INFO


# ------------------------------------------------------------------------------
# Storage
# ------------------------------------------------------------------------------

# Primary database connection string.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/moltbook


# ------------------------------------------------------------------------------
# AI Services
# ------------------------------------------------------------------------------

# Ollama base URL used for scoring and content generation.
OLLAMA_BASE_URL=http://localhost:11434

# Ollama model name used by the pipeline.
OLLAMA_MODEL=qwen3.5:4b-q4_K_M

# HTTP timeout in seconds for Ollama scoring and review generation calls.
OLLAMA_TIMEOUT_SECONDS=300

# Optional translation target for review text and comments, for example zh, ja, or ko.
# Leave empty to disable translation.
TRANSLATION_LANGUAGE=

# Output language for auto-generated Threads draft text.
THREADS_LANGUAGE=en


# ------------------------------------------------------------------------------
# Upstream APIs
# ------------------------------------------------------------------------------

# Moltbook API base URL.
MOLTBOOK_API_BASE_URL=https://api.moltbook.internal

# Moltbook API token.
MOLTBOOK_API_TOKEN=

# Threads API base URL.
THREADS_API_BASE_URL=https://graph.threads.net

# Threads API token.
THREADS_API_TOKEN=

# Threads account ID used for publishing.
THREADS_ACCOUNT_ID=


# ------------------------------------------------------------------------------
# Telegram
# ------------------------------------------------------------------------------

# Telegram bot token from BotFather.
# Leave empty to disable Telegram features.
TELEGRAM_BOT_TOKEN=

# Single authorized Telegram chat ID for commands and notifications.
TELEGRAM_CHAT_ID=

# Public HTTPS webhook URL, for example:
# https://host.example/telegram/webhook
TELEGRAM_WEBHOOK_URL=

# Daily summary delivery hour in 24-hour format (0-23).
TELEGRAM_DAILY_SUMMARY_HOUR=22

# IANA timezone name for the daily summary schedule.
TELEGRAM_DAILY_SUMMARY_TIMEZONE=UTC


# ------------------------------------------------------------------------------
# Publishing
# ------------------------------------------------------------------------------

# Publishing mode: manual-approval or semi-auto.
PUBLISH_MODE=manual-approval

# Maximum number of posts that may be published per day.
MAX_PUBLISH_PER_DAY=5

# Default Moltbook ingestion time window.
INGESTION_TIME=hour

# Default Moltbook ingestion post limit.
INGESTION_LIMIT=20

# Default Moltbook ingestion sort order.
INGESTION_SORT=top

# Minimum score required to enter the review queue.
REVIEW_MIN_SCORE=3.5

# Minimum score required for semi-auto publish eligibility.
AUTO_PUBLISH_MIN_SCORE=4.0
